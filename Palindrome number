class Solution {
    public boolean isPalindrome(int x) {
        int t = x;
        int r=0;
        while(x > 0)
        {
            int l = x%10;
            r = l + r*10;
            x= x/10;
        }
        if(r == t)
        {
            return true;
        }
        return false;
    }
}
