class Solution {
    public int lengthOfLongestSubstring(String s) 
    {
        HashSet<Character> h = new HashSet<>();
        int l = 0;
        int m =0;
        for(int i=0;i<s.length();i++)
        {
            while(h.contains(s.charAt(i)))
            {
                h.remove(s.charAt(l));
                l++;
            }
            h.add(s.charAt(i));
              m = Math.max(m,i-l+1);

        }
        return m;
    }
}
