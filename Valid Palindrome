class Solution {
    public boolean isPalindrome(String s) {
        String c = s.toLowerCase();
        String a ="";
    for(int i=0;i<c.length();i++)
    { 
        if((c.charAt(i) >= '0' && c.charAt(i) <='9' )||(c.charAt(i) >= 'a' && c.charAt(i) <= 'z'))
        {
           a+=c.charAt(i);
        }
    }
    String b ="";
     for(int i=a.length()-1;i>=0;i--)
    {
           b+=a.charAt(i);
    }
    if(a.equals(b))
    {
        return true;
    }  
     else{
        return false;
}
    }

}
