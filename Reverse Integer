class Solution {
    public int reverse(int x) {
        int m =0;
        int r =0;
        while(Math.abs(x)>0)
        {
          m = x%10;
          x = x/10;
         if(r > Integer.MAX_VALUE/10 || r < Integer.MIN_VALUE/10)
         {
            return 0;
         }
          r = r*10 + m ;
    }
         return r;
    }
}
