class Solution {
    public int lengthOfLastWord(String s) {
           String b = s.trim();
        
        for(int i = b.length()-1;i>=0;i--)
        {   
             if(b.charAt(i) == ' ')
            {
                return b.substring(i+1,b.length()).length();
                
            }
        }
        
        return b.length();
        
    }
}
